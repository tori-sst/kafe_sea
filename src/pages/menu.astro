---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout pageTitle="Меню">
    <section class="flex wrap-break-word justify-around items-center w-screen p-12.5">
        <div class="w-screen p-12.5 overflow-x-scroll">
        <table class="max-sm:text-[15px] text-[1.1em] w-[60%] border-collapse mx-auto text-[#cbe3f8] bg-[#29373e]/42">
            <thead class=" bg-[#29373e]/93">
                <tr>
                    <th>Фото блюда</th>
                    <th>Название и состав блюда</th>
                    <th>Цена (руб.)</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        <img src="/kafe_sea/images/hand-holding-drink-beach-against-sky-sunset_1048944-30400447.avif" alt="Коктейль" class="img-menu">
                    </td>
                    <td class="text-left px-5">Экзотический коктейль
                        <ol class="ol-menu">
                            <li>Лимон</li>
                            <li>Вода</li>
                            <li>Без сахара</li>
                        </ol>
                    </td>
                    <td>800 руб.
                        <br><br>
                        <button class="button-menu">
                            <a href="/kafe_sea/sakas" class=" text-[#29373e]/93">Заказать</a>
                        </button>
                    </td>
                </tr>
                <tr>
                    <td>
                        <img src="/kafe_sea/images/hawaiian-pizza-against-tropical-beach-background_975188-64294.avif" alt="Пицца" class="img-menu">
                    </td>
                    <td class="text-left px-5">Морская пицца
                        <ol class="ol-menu">    
                            <li>Помидоры</li>
                            <li>Курица</li>
                            <li>Ананас</li>
                        </ol>
                    </td>
                    <td>1200 руб.
                        <br><br>
                        <button class="button-menu">
                            <a href="/kafe_sea/sakas"  class="text-[#29373e]/93">Заказать</a>
                        </button>
                    </td>
                </tr>
                <tr>
                    <td>
                        <img src="/kafe_sea/images/recept-15588-1240x825.jpg" alt="Фруктовый салат" class="img-menu">
                    </td>
                    <td class="text-left px-5">Свежий фруктовый салат
                        <ol class="ol-menu">    
                            <li>Банан</li>
                            <li>Яблоко</li>
                            <li>Киви</li>
                            <li>Манго</li>
                            <li>Апельсин</li>
                        </ol>
                    </td>
                    <td>600 руб.
                        
                        <br><br>
                        <button class="button-menu">
                            <a href="/kafe_sea/sakas"  class="text-[#29373e]/93" >Заказать</a>
                        </button>
                    </td>
                </tr>
                <tr>
                    <td>
                        <img src="/kafe_sea/images/close-up-fish-leaves_1048944-14370828.avif" alt="Жареный лосось" class="img-menu"></td>
                    <td class="text-left px-5">Жареный лосось
                        <ol class="ol-menu">
                            <li>Лосось свежего улова</li>
                            <li>Зелень местная</li>
                        </ol>
                    </td>
                    <td>2500 руб.
                        <br><br>
                        <button class="button-menu">
                            <a href="/kafe_sea/sakas"  class="text-[#29373e]/93">Заказать</a>
                        </button>
                    </td>
                </tr>
            </tbody>
        </table>
        </div>
    </section>
</BaseLayout>