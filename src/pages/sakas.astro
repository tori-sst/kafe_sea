---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout pageTitle="Заказ">
    <section class="flex flex-wrap justify-center items-center gap-4 w-[80vw] h-auto">
    <form>
            <h2 class="font-semibold text-[1.5em] text-white m-4">Оформите заказ:</h2>
                <input type="text" name="имя" placeholder="Введите ваше имя:"> 
                <br><br>
                <select multiple name="menu" size="1">
            
                    <option value="coctail" class="font-mono">Экзотический коктейль</option>
                    <option value="pizza" class="font-mono">Морская пицца</option>
                    <option value="salat" class="font-mono">Свежий фруктовый салат</option>
                    <option value="fish"class="font-mono">Жареный лосось</option>
                </select>
                <br><br>
                <input type="number" name="номер" placeholder="Введите номер столика:" >
                <br><br>
                
                <button type="submit">Сделать заказ</button>
            
            </form>
            <img src="/kafe_sea/images/more-tropiki-okean-plyazh-pesok.webp" alt="море" class="block object-cover w-[55%] min-w-72.5 h-auto max-h-[60vh] rounded-[5px] ">
   </section>
</BaseLayout>