---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';

const responseUI = await fetch('http://localhost:1337/api/ui-components?populate=*');
const jsonUI = await responseUI.json();
const uiItems = jsonUI.data || [];
console.log(uiItems);

const ui: Record<string, string> = {};
uiItems.forEach((item: any) => {

    const alt = item.alt;
    const url = item.image?.url;
    
    if (alt && url) {
        ui[alt] = `http://localhost:1337${url}`;
    }
});
---
<BaseLayout pageTitle="Отзыв">
    <section class="flex flex-wrap justify-around items-center w-screen">
    
        <form>
            <h2 class="font-semibold text-[1.5em] text-white m-4">Оставьте отзыв:</h2>
            <input type="text" name="name" id="name" placeholder="Введите ваше имя:"><br>
            <textarea name="comment" id="comment" rows="4" placeholder="Напишите Ваш отзыв..."></textarea><br><br>
            <button type="submit">Отправить отзыв</button>
        </form>

        <img src={ui["star-image"]} alt="star-image" class="order-1 max-lg:order-0 max-w-100 min-w-72.5 w-auto h-auto m-2 rounded-[5px] object-cover">
        <img src={ui["staff_image"]} alt="staff-image" class="hidden xl:block -order-1 max-lg:order-1 max-w-100 min-w-72.5 w-auto h-auto m-2 rounded-[5px] object-cover">
    </section>

</BaseLayout>