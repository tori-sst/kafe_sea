---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout pageTitle="Отзыв">
    <section class="flex flex-wrap justify-around items-center w-screen">
    
        <form>
            <h2 class="font-semibold text-[1.5em] text-white m-4">Оставьте отзыв:</h2>
            <input type="text" name="name" id="name" placeholder="Введите ваше имя:"><br>
            <textarea name="comment" id="comment" rows="4" placeholder="Напишите Ваш отзыв..."></textarea><br><br>
            <button type="submit">Отправить отзыв</button>
        </form>

        <img src="/images/star.jpg" alt="Left Image" class="order-1 max-lg:order-0 max-w-100 min-w-72.5 w-auto h-auto m-2 rounded-[5px] object-cover">
        <img src="/images/персонал.jpg" alt="Right Image" class="hidden xl:block -order-1 max-lg:order-1 max-w-100 min-w-72.5 w-auto h-auto m-2 rounded-[5px] object-cover">
    </section>

</BaseLayout>